
import time
import requests
import telebot
import threading
from datetime import datetime

# === АВТОМАТИЧЕСКАЯ НАСТРОЙКА ТОКЕНОВ И КЛЮЧЕЙ ===
TELEGRAM_TOKEN = "ВАШ_ТЕЛЕГРАМ_ТОКЕН"  # Вставьте ваш токен от @BotFather сюда
SSTATS_API_KEY = "ВАШ_КЛЮЧ_SSTATS"       # Вставьте ваш API-ключ от SStats сюда
BASE_URL = "https://sstats.net"

bot = telebot.TeleBot(TELEGRAM_TOKEN)

# Настройка заголовков авторизации для API SStats
headers = {
    "Authorization": f"Bearer {SSTATS_API_KEY}",
    "Accept": "application/json"
}

def safe_float(value, default=0.0):
    """Защита от болезней ботов: безопасная конвертация типов данных."""
    if value is None:
        return default
    try:
        return float(value)
    except (ValueError, TypeError):
        return default

def get_team_stats_safe(team_id, side):
    """Безопасный запрос к API с ограничением по времени и обработкой ошибок."""
    try:
        url = f"{BASE_URL}/teams/{team_id}/stats"
        # Тайм-аут 10 секунд защищает от вечного зависания при сбое сети sstats
        response = requests.get(url, headers=headers, timeout=10)
        
        if response.status_code == 200:
            response_data = response.json()
            
            # Регистронезависимая проверка статуса внутри запроса команды
            status = str(response_data.get("status", "")).lower()
            if status != "ok":
                return 0.0
                
            data = response_data.get('data', {}) if 'data' in response_data else response_data
            if side == 'home':
                return safe_float(data.get('home_goals_scored_avg'))
            elif side == 'away':
                return safe_float(data.get('away_goals_conceded_avg'))
        return 0.0
    except Exception as e:
        print(f"Ошибочный ответ сети для команды {team_id}: {e}")
        return 0.0

def process_predictions_async(chat_id):
    """Асинхронный движок анализа матчей, работающий в фоновом режиме."""
    today_date = datetime.now().strftime("%Y-%m-%d")
    matches_url = f"{BASE_URL}/matches"
    params = {"date": today_date}
    
    try:
        bot.send_message(chat_id, "🔍 Подключаюсь к SStats API... Начинаю анализ матчей.")
        response = requests.get(matches_url, headers=headers, params=params, timeout=10)
        
        if response.status_code != 200:
            bot.send_message(chat_id, "⚠️ Ошибка связи с API SStats. Проверьте правильность SSTATS_API_KEY.")
            return
            
        response_data = response.json()
        
        # ИСПРАВЛЕНИЕ: Регистронезависимая проверка статуса ответа API ("ok", "OK", "Ok")
        status = str(response_data.get("status", "")).lower()
        if status != "ok":
            bot.send_message(chat_id, f"⚠️ API вернул статус ошибки: {response_data.get('status')}")
            return
            
        matches = response_data.get('data', [])
        if not matches:
            bot.send_message(chat_id, "📅 В базе SStats на сегодня матчей для анализа не обнаружено.")
            return
            
        found_signals = 0
        
        for match in matches:
            home_name = match.get('home_team_name', 'Хозяева')
            away_name = match.get('away_team_name', 'Гости')
            league = match.get('league_name', 'Лига')
            
            home_id = match.get('home_team_id')
            away_id = match.get('away_team_id')
            
            # Извлекаем рейтинги Глико-2
            home_glicko = safe_float(match.get('home_glicko'), 1500.0)
            away_glicko = safe_float(match.get('away_glicko'), 1500.0)
            
            # КРИТЕРИЙ 1: Порог разницы рейтинга Глико (от 100 пунктов)
            if (home_glicko - away_glicko) < 100:
                continue
                
            # ОЗДОРОВЛЕНИЕ БОТА: Обязательная пауза перед запросом, чтобы не спамить эндпоинты sstats
            time.sleep(1.5)
            
            # Запрашиваем точечную статистику команд
            home_goals_avg = get_team_stats_safe(home_id, 'home')
            away_conceded_avg = get_team_stats_safe(away_id, 'away')
            
            # КРИТЕРИИ 2 и 3: Порог результативности строго больше 1.3 голов
            if home_goals_avg > 1.3 and away_conceded_avg > 1.3:
                found_signals += 1
                
                # Формируем динамический индекс математической уверенности
                score_weight = (home_goals_avg + away_conceded_avg) * 12
                glicko_weight = (home_glicko - away_glicko) / 5
                probability = min(99, int(score_weight + glicko_weight))
                
                message_text = (
                    f"⭐ **СИГНАЛ: ИТБ1 (0.5)**\n"
                    f"🏆 Лига: {league}\n"
                    f"⚔️ Матч: {home_name} — {away_name}\n"
                    f"📈 Рейтинг Glicko-2: {int(home_glicko)} vs {int(away_glicko)} (Разница: +{int(home_glicko-away_glicko)})\n"
                    f"⚽️ Ср. голов дома (Хозяева): {home_goals_avg}\n"
                    f"🛡 Ср. пропущено в гостях (Гости): {away_conceded_avg}\n\n"
                    f"🎯 **Вероятность захода: {probability}%**"
                )
                
                bot.send_message(chat_id, message_text, parse_mode="Markdown")
                
        if found_signals == 0:
            bot.send_message(chat_id, "ℹ️ Сканирование завершено. Матчей под критерии (Глико > 100, голы > 1.3) сегодня нет.")
        else:
            bot.send_message(chat_id, f"✅ Анализ окончен. Всего найдено подходящих матчей: {found_signals}")
            
    except Exception as general_error:
        bot.send_message(chat_id, f"❌ Критическая системная ошибка в цикле: {general_error}")

# === ИНТЕРФЕЙС И ОБРАБОТЧИКИ ТЕЛЕГРАМ ===

@bot.message_handler(commands=['start'])
def welcome_user(message):
    bot.reply_to(
        message,
        "🤖 Исправленный бот-сканер SStats готов к работе.\n"
        "Нажмите /predict для запуска поиска матчей на **ИТБ1 (0.5)**.\n"
        "Текущие фильтры: Разница Glicko > 100, Ср. голы > 1.3, Регистронезависимость активна.",
        parse_mode="Markdown"
    )

@bot.message_handler(commands=['predict'])
def run_prediction_thread(message):
    # Запуск логики в threading.Thread избавляет бота от зависаний при обработке длинных очередей
    threading.Thread(target=process_predictions_async, args=(message.chat.id,)).start()

if __name__ == '__main__':
    print("Бот успешно инициализирован и запущен в режиме Long Polling...")
    
    # Бесконечный цикл с защитой от разрыва соединения с серверами Telegram
    while True:
        try:
            bot.polling(none_stop=True, interval=0, timeout=20)
        except Exception as telegram_error:
            print(f"Сбой связи с Telegram: {telegram_error}. Перезапуск через 5 секунд...")
            time.sleep(5)

