# ============ НАСТРОЙКИ ============
BAD_LEAGUES = ["women", "female", "friendlies", "friendly", "u17", "u18", "u19", "u20", "u21", "youth",
               "2nd division", "3rd division", "4th division", "serie c", "serie d", "liga 2", "liga 3",
               "national league", "isthmian", "northern premier", "southern league", "western league"]

BASELINE = {
    "Premier League": 4.8, "La Liga": 4.5, "Serie A": 4.3,
    "Bundesliga": 5.2, "Ligue 1": 4.6, "Russian Premier League": 4.0,
    "default": 4.5
}

MIN_Glicko = 1500
MIN_ODDS = 1.20
ITB_LINE = 0.5
SCAN_HOUR = 10
