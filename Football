            text += f"Recommendation: ITB 0.5 **{best[0]}** ({best[1]}) - {best[2]}%"
        else:
            text += "No confident recommendations (probability < 65%)"

        await message.answer(text)

    except Exception as e:
        logging.exception("Manual analysis error")
        await message.answer("Analysis error. Try later.")

@dp.message()
async def unknown(message: Message):
    await message.answer(
        "I did not understand.\n\n"
        "Press **Scan matches today** for auto search\n"
        "Or enter: `Team1 - Team2` for manual analysis"
    )

