import os
import logging
import requests
from aiogram import Bot, Dispatcher, F
from aiogram.types import Message, ReplyKeyboardMarkup, KeyboardButton

# 1. Настройка логирования для вывода в консоль Bothost
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s"
)

# 2. Безопасное получение токенов из панели управления хостинга
BOT_TOKEN = os.getenv("BOT_TOKEN")
RAPIDAPI_KEY = os.getenv("RAPIDAPI_KEY")
RAPIDAPI_HOST = "://rapidapi.com"

if not BOT_TOKEN or not RAPIDAPI_KEY:
    logging.critical("ОШИБКА: Проверьте переменные окружения BOT_TOKEN и RAPIDAPI_KEY на Bothost!")
    raise ValueError("Критические переменные окружения не настроены!")

bot = Bot(token=BOT_TOKEN)
dp = Dispatcher()

# Главная клавиатура
main_kb = ReplyKeyboardMarkup(
    keyboard=[[KeyboardButton(text="⚽ Анализ ИТБ")]],
    resize_keyboard=True
)

@dp.message(F.text == "/start")
async def cmd_start(message: Message):
    logging.info(f"Пользователь {message.from_user.id} запустил бота")
    await message.answer(
        "👋 Привет! Я бот-аналитик футбольного **ИТБ**.\n"
        "Отправь мне названия двух команд через дефис, чтобы узнать прогноз.\n"
        "Пример: `Real Madrid - Barcelona` (лучше писать на английском)", 
        reply_markup=main_kb,
        parse_mode="Markdown"
    )

@dp.message(F.text == "⚽ Анализ ИТБ")
async def ask_teams(message: Message):
    await message.answer("Введите две команды в формате: `Команда1 - Команда2`")

def get_team_id(team_name: str):
    """Поиск ID команды по названию через API-Football"""
    url = f"https://{RAPIDAPI_HOST}/v3/teams"
    querystring = {"search": team_name}
    headers = {"X-RapidAPI-Key": RAPIDAPI_KEY, "X-RapidAPI-Host": RAPIDAPI_HOST}
    
    try:
        logging.info(f"Запрос ID для команды: {team_name}")
        response = requests.get(url, headers=headers, params=querystring, timeout=10).json()
        if response.get("response"):
            # Берем первый найденный результат
            team_data = response["response"][0]["team"]
            return team_data["id"], team_data["name"]
    except Exception as e:
        logging.error(f"Ошибка при поиске ID команды {team_name}: {e}")
    return None, None

def get_average_goals(team_id: int):
    """Получение среднего тотала за последние 5 матчей"""
    url = f"https://{RAPIDAPI_HOST}/v3/fixtures"
    querystring = {"team": team_id, "last": "5"}
    headers = {"X-RapidAPI-Key": RAPIDAPI_KEY, "X-RapidAPI-Host": RAPIDAPI_HOST}
    
    try:
        logging.info(f"Запрос последних 5 матчей для ID: {team_id}")
        response = requests.get(url, headers=headers, params=querystring, timeout=10).json()
        fixtures = response.get("response", [])
        if not fixtures:
            return 0.0
            
        total_goals = 0
        games_counted = 0
        
        for f in fixtures:
            goals = f.get("goals", {})
            if f["teams"]["home"]["id"] == team_id:
                total_goals += goals.get("home", 0) or 0
            else:
                total_goals += goals.get("away", 0) or 0
            games_counted += 1
            
        return round(total_goals / games_counted, 2) if games_counted > 0 else 0.0
    except Exception as e:
        logging.error(f"Ошибка при получении голов для ID {team_id}: {e}")
        return 0.0

@dp.message()
async def analyze_match(message: Message):
    if "-" not in message.text:
        return

    teams = message.text.split("-")
    if len(teams) != 2:
        await message.answer("❌ Неверный формат. Используйте: Команда1 - Команда2")
        return

    t1_name = teams[0].strip()
    t2_name = teams[1].strip()
    
    logging.info(f"Запрос анализа матча: {t1_name} против {t2_name}")
    await message.answer(f"⏳ Ищу статистику для {t1_name} и {t2_name}...")

    t1_id, t1_correct_name = get_team_id(t1_name)
    t2_id, t2_correct_name = get_team_id(t2_name)

    if not t1_id or not t2_id:
        await message.answer("❌ Одна из команд не найдена. Попробуйте написать название на английском (например, Real Madrid).")
        return

    t1_avg = get_average_goals(t1_id)
    t2_avg = get_average_goals(t2_id)

    # Простейший алгоритм рекомендации ИТБ
    itb1_suggestion = "ИТБ1 (1.0)" if t1_avg >= 1.2 else "ИТБ1 (0.5)"
    if t1_avg >= 1.8: itb1_suggestion = "ИТБ1 (1.5)"

    itb2_suggestion = "ИТБ2 (1.0)" if t2_avg >= 1.2 else "ИТБ2 (0.5)"
    if t2_avg >= 1.8: itb2_suggestion = "ИТБ2 (1.5)"

    report = (
        f"📊 **Анализ индивидуального тотала:**\n\n"
        f"🏠 **{t1_correct_name}**:\n"
        f"• Средний тотал за 5 игр: {t1_avg} гола(ов)\n"
        f"• Рекомендуемая ставка: **{itb1_suggestion}**\n\n"
        f"🚀 **{t2_correct_name}**:\n"
        f"• Средний тотал за 5 игр: {t2_avg} гола(ов)\n"
        f"• Рекомендуемая ставка: **{itb2_suggestion}**"
    )
    
    await message.answer(report, parse_mode="Markdown")

if __name__ == "__main__":
    import asyncio
    logging.info("Бот успешно запущен и начинает опрос серверов Telegram...")
    asyncio.run(dp.start_polling(bot))


