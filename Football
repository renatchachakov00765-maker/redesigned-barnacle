# === API WITH RATE LIMIT + RETRY + LOGGING ===
def api_get(endpoint: str, params: dict = None, retries: int = 3):
    url = f"{API_BASE_URL}{endpoint}"
    p = params or {}

    # Ключ передаем в заголовках, не в URL
    headers = {
        "Connection": "close",
        "Accept": "application/json",
        "User-Agent": "SStatsBot/1.0"
    }
    if SSTATS_KEY:
        headers["apikey"] = SSTATS_KEY

    rate_limit()

    for attempt in range(retries):
        try:
            response = session.get(url, params=p, timeout=15, headers=headers)
            response.raise_for_status()
            data = response.json()
            logging.info(f"API OK {endpoint}: status={response.status_code}, keys={list(data.keys()) if isinstance(data, dict) else 'list'}, count={len(data) if isinstance(data, list) else (len(data.get('data', [])) if isinstance(data, dict) else 'N/A')}")
            return data
        except requests.exceptions.ConnectionError as e:
            logging.error(f"ConnectionError {endpoint} attempt {attempt+1}/{retries}: {e}")
            if attempt == 0 and SSTATS_KEY:
                # Fallback: пробуем без ключа
                logging.info("Retrying without apikey in headers...")
                try:
                    fallback_headers = {
                        "Connection": "close",
                        "Accept": "application/json",
                        "User-Agent": "SStatsBot/1.0"
                    }
                    response = session.get(url, params=p, timeout=15, headers=fallback_headers)
                    response.raise_for_status()
                    data = response.json()
                    logging.info(f"API OK {endpoint} (fallback no key): status={response.status_code}")
                    return data
                except Exception as e2:
                    logging.error(f"Fallback also failed: {e2}")
            if attempt < retries - 1:
                time.sleep(2 * (attempt + 1))
            else:
                return None
        except Exception as e:
            logging.error(f"API error {endpoint} attempt {attempt+1}/{retries}: {e}")
            if attempt < retries - 1:
                time.sleep(2 * (attempt + 1))
            else:
                return None

def get_leagues():
    """Получить список лиг с кэшированием."""
    global _leagues_cache, _leagues_cache_time
    now = datetime.now()
    if _leagues_cache and _leagues_cache_time and (now - _leagues_cache_time).seconds < 3600:
        return _leagues_cache

    data = api_get("/leagues")
    if data and data.get("status") == "ok" and data.get("data"):
        _leagues_cache = data["data"]
        _leagues_cache_time = now
        logging.info(f"Loaded {len(_leagues_cache)} leagues")
        return _leagues_cache

    logging.warning("Failed to load leagues or empty response")
    return []

def get_team_id(team_name: str):
    key = team_name.lower().strip()
    if key in _team_cache:
        return _team_cache[key]

    data = api_get("/teams/list", {"Name": team_name, "Limit": 10})
    if data and data.get("status") == "ok" and data.get("data"):
        teams = data["data"]
        for t in teams:
            if team_name.lower() in t.get("name", "").lower() or t.get("name", "").lower() in team_name.lower():
                result = (t["id"], t["name"])
                _team_cache[key] = result
                return result
        if teams:
            result = (teams[0]["id"], teams[0]["name"])
            _team_cache[key] = result
            return result

    return None, None

def get_team_matches(team_id: int, limit: int = 10, is_home: bool = None):
    now = datetime.now()
    cache_key = f"{team_id}_{is_home}"
    if cache_key in _cache_time and (now - _cache_time[cache_key]).seconds < 300:
        return _matches_cache.get(cache_key, [])

    params = {
        "Team": team_id,
        "Ended": "true",
        "Limit": limit * 2,
        "Order": -1,
    }

    data = api_get("/games/list", params)
    if not data or data.get("status") != "ok" or not data.get("data"):
        return []

    matches = data["data"]
    result = []
    for m in matches:
        home_id = m.get("homeTeam", {}).get("id")
        away_id = m.get("awayTeam", {}).get("id")

        if home_id == team_id:
            goals_scored = int(m.get("homeResult", 0) or 0)
            match_is_home = True
        elif away_id == team_id:
            goals_scored = int(m.get("awayResult", 0) or 0)
            match_is_home = False
        else:
            continue

        if is_home is not None and match_is_home != is_home:
            continue

        result.append((m, goals_scored))
        if len(result) >= limit:
            break

    _matches_cache[cache_key] = result
    _cache_time[cache_key] = now
    return result

def get_today_fixtures(max_matches: int = 10):
    """Получить матчи на сегодня через /games/list?LeagueId=&Year="""
    today = datetime.now().strftime("%Y-%m-%d")

    # Получаем список лиг
    leagues = get_leagues()
    if not leagues:
        logging.warning("No leagues loaded")
        return []

    all_matches = []
    current_year = datetime.now().year  # 2026

    # Запрашиваем матчи для каждой лиги
    # Ограничиваем количество лиг для скорости
    target_leagues = leagues[:25]  # Первые 25 лиг

    for league in target_leagues:
        league_id = league.get("id")
        league_name = league.get("name", "?")
        if not league_id:
            continue

        params = {
            "LeagueId": league_id,
            "Year": current_year,
            "Limit": 30
        }

        data = api_get("/games/list", params)

        if data and data.get("status") == "ok":
            matches = data.get("data", [])
            if matches:
                logging.info(f"League {league_id} ({league_name}): {len(matches)} matches loaded")
                all_matches.extend(matches)

    # Фильтруем по сегодняшней дате
    today_matches = []
    for m in all_matches:
        match_date = m.get("date") or m.get("matchDate") or m.get("Date") or m.get("startDate")
        if match_date:
            match_date_str = str(match_date)[:10]
            if today == match_date_str:
                today_matches.append(m)

    logging.info(f"Total matches for {today}: {len(today_matches)}")

    # Сортируем по времени
    today_matches.sort(key=lambda x: x.get("date", "") or x.get("matchDate", ""))

    return today_matches[:max_matches]

# === PROBABILITY CALC ===
def poisson_probability(lambda_val: float, target: int = 1):
    import math
    if target == 1:
        return round((1 - math.exp(-lambda_val)) * 100, 1)
    return 0

def calculate_advanced_itb(team_id: int, is_home: bool):
    matches = get_team_matches(team_id, limit=10, is_home=is_home)
    if not matches:
        return None, "No data"

    if len(matches) < 3:
        return None, f"Few matches ({len(matches)})"

    goals_list = [g for _, g in matches]
    lambda_base = sum(goals_list) / len(goals_list)

    weights = [0.15, 0.25, 0.40]
    recent_goals = goals_list[:3]
    weighted_avg = sum(g * w for g, w in zip(recent_goals, weights[:len(recent_goals)])) / sum(weights[:len(recent_goals)])

    lambda_final = lambda_base * 0.6 + weighted_avg * 0.4
    prob = poisson_probability(lambda_final, 1)

    if lambda_final > 1.5 and prob < 60:
        prob = min(75, prob + 10)

    return {
        "probability": prob,
        "lambda": round(lambda_final, 2),
        "avg_goals": round(lambda_base, 2),
        "matches_count": len(matches),
        "confidence": "High" if len(matches) >= 5 else "Medium",
    }, None

# === SCANNER ===
_scan_results = {}

async def scan_matches(user_id: int):
    fixtures = get_today_fixtures(max_matches=10)

    if not fixtures:
        return None, "API returned no matches for today. Enter manually: Team1 - Team2"

    recommendations = []

    for fixture in fixtures:
        home_team = fixture.get("homeTeam", {})
        away_team = fixture.get("awayTeam", {})
        home_name = home_team.get("name", "")
        away_name = away_team.get("name", "")
        match_time = fixture.get("date", "??")

        if not home_name or not away_name:
            continue

        home_id, _ = get_team_id(home_name)
        away_id, _ = get_team_id(away_name)

        if not home_id or not away_id:
            continue

        home_stats, _ = calculate_advanced_itb(home_id, is_home=True)
        away_stats, _ = calculate_advanced_itb(away_id, is_home=False)

        if home_stats and home_stats["probability"] >= 65:
            recommendations.append({
                "match": f"{home_name} - {away_name}",
                "time": match_time,
                "team": home_name,
                "side": "home",
                "probability": home_stats["probability"],
                "avg_goals": home_stats["avg_goals"],
                "confidence": home_stats["confidence"],
            })

        if away_stats and away_stats["probability"] >= 65:
            recommendations.append({
                "match": f"{home_name} - {away_name}",
                "time": match_time,
                "team": away_name,
                "side": "away",
                "probability": away_stats["probability"],
                "avg_goals": away_stats["avg_goals"],
                "confidence": away_stats["confidence"],
            })

    recommendations.sort(key=lambda x: x["probability"], reverse=True)
    _scan_results[user_id] = recommendations

    return recommendations, None

