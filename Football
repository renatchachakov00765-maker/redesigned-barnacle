
import os
import sys
import logging
import requests
import asyncio
from aiogram import Bot, Dispatcher, F
from aiogram.types import Message, ReplyKeyboardMarkup, KeyboardButton
from aiogram.client.default import DefaultBotProperties
from aiohttp import web

sys.stdout.reconfigure(line_buffering=True)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s",
    stream=sys.stdout
)

BOT_TOKEN = os.getenv("BOT_TOKEN")
SSTATS_KEY = os.getenv("SSTATSKEY")

if not BOT_TOKEN:
    logging.critical("BOT_TOKEN не найден!")
    sys.exit(1)
if not SSTATS_KEY:
    logging.critical("SSTATSKEY не найден!")
    sys.exit(1)

API_BASE_URL = "https://sstats.net"

bot = Bot(token=BOT_TOKEN, default=DefaultBotProperties(parse_mode="Markdown"))
dp = Dispatcher()

main_kb = ReplyKeyboardMarkup(
    keyboard=[[KeyboardButton(text="⚽ Анализ ИТБ")]],
    resize_keyboard=True
)

@dp.message(F.text == "/start")
async def cmd_start(message: Message):
    await message.answer(
        "👋 Привет! Отправь две команды через дефис.\nПример: `Реал Мадрид - Барселона`",
        reply_markup=main_kb
    )

@dp.message(F.text == "⚽ Анализ ИТБ")
async def ask_teams(message: Message):
    await message.answer("Введите: `Команда1 - Команда2`")

def get_team_id(team_name: str):
    url = f"{API_BASE_URL}/teams/search"
    params = {"query": team_name.strip(), "api_key": SSTATS_KEY}
    try:
        response = requests.get(url, params=params, timeout=10)
        response.raise_for_status()
        data = response.json()
        if data and isinstance(data, list) and len(data) > 0:
            return data[0]["id"], data[0]["name"]
    except Exception as e:
        logging.error(f"Ошибка поиска команды '{team_name}': {e}")
    return None, None

def get_average_goals(team_id: int):
    url = f"{API_BASE_URL}/teams/{team_id}/matches"
    params = {"limit": 5, "api_key": SSTATS_KEY}
    try:
        response = requests.get(url, params=params, timeout=10)
        response.raise_for_status()
        data = response.json()
        matches = data.get("matches", []) if isinstance(data, dict) else []
        if not matches:
            return 0.0
        total = sum(
            m.get("home_score", 0) if m.get("home_team_id") == team_id else m.get("away_score", 0)
            for m in matches[:5]
        )
        return round(total / len(matches[:5]), 2)
    except Exception as e:
        logging.error(f"Ошибка получения матчей team_id={team_id}: {e}")
        return 0.0

# ✅ ИСПРАВЛЕНО: фильтр только на сообщения с дефисом + полный try/except
@dp.message(F.text.contains("-"))
async def analyze_match(message: Message):
    try:
        teams = message.text.split("-")
        if len(teams) != 2:
            await message.answer("❌ Формат: `Команда1 - Команда2`")
            return

        t1_name, t2_name = teams[0].strip(), teams[1].strip()
        await message.answer(f"⏳ Ищу `{t1_name}` и `{t2_name}`...")

        t1_id, t1_found = get_team_id(t1_name)
        t2_id, t2_found = get_team_id(t2_name)

        if not t1_id or not t2_id:
            await message.answer("❌ Одна или обе команды не найдены")
            return

        t1_avg = get_average_goals(t1_id)
        t2_avg = get_average_goals(t2_id)

        itb1 = "ИТБ1 (1.5)" if t1_avg >= 1.8 else "ИТБ1 (1.0)" if t1_avg >= 1.2 else "ИТБ1 (0.5)"
        itb2 = "ИТБ2 (1.5)" if t2_avg >= 1.8 else "ИТБ2 (1.0)" if t2_avg >= 1.2 else "ИТБ2 (0.5)"

        await message.answer(
            f"📊 **{t1_found}**: {t1_avg} гола → {itb1}\n"
            f"🚀 **{t2_found}**: {t2_avg} гола → {itb2}"
        )
    except Exception as e:
        logging.exception("Ошибка в analyze_match")
        await message.answer("❌ Произошла ошибка при анализе. Попробуй позже.")

# ✅ Добавлен: хендлер для всего остального (чтобы не было тишины)
@dp.message()
async def unknown_message(message: Message):
    await message.answer(
        "❓ Я не понял. Отправь две команды через дефис.\n"
        "Пример: `Реал Мадрид - Барселона`"
    )

async def health(request):
    return web.Response(text="OK", status=200)

async def main():
    app = web.Application()
    app.router.add_get("/", health)

    runner = web.AppRunner(app)
    await runner.setup()
    site = web.TCPSite(runner, "0.0.0.0", 8080)
    await site.start()
    logging.info("Health server on 0.0.0.0:8080")

    logging.info("Start polling")
    await dp.start_polling(bot, skip_updates=True)

if __name__ == "__main__":
    asyncio.run(main())
