# === API SSTATS ===
def api_get(endpoint: str, params: dict = None):
    url = f"{API_BASE_URL}{endpoint}"
    p = params or {}
    if SSTATS_KEY:
        p["apikey"] = SSTATS_KEY
    try:
        response = requests.get(url, params=p, timeout=10)
        response.raise_for_status()
        return response.json()
    except Exception as e:
        logging.error(f"API error {endpoint}: {e}")
        return None

def get_team_id(team_name: str):
    key = team_name.lower().strip()
    if key in _team_cache:
        return _team_cache[key]

    data = api_get("/Teams/list", {"Name": team_name, "Limit": 10})
    if data and data.get("status") == "ok" and data.get("data"):
        teams = data["data"]
        for t in teams:
            if team_name.lower() in t.get("name", "").lower() or t.get("name", "").lower() in team_name.lower():
                result = (t["id"], t["name"])
                _team_cache[key] = result
                return result
        if teams:
            result = (teams[0]["id"], teams[0]["name"])
            _team_cache[key] = result
            return result

    return None, None

def get_team_matches(team_id: int, limit: int = 10, is_home: bool = None):
    now = datetime.now()
    cache_key = f"{team_id}_{is_home}"
    if cache_key in _cache_time and (now - _cache_time[cache_key]).seconds < 300:
        return _matches_cache.get(cache_key, [])

    params = {
        "Team": team_id,
        "Ended": "true",
        "Limit": limit * 2,
        "Order": -1,
    }

    data = api_get("/Games/list", params)
    if not data or data.get("status") != "ok" or not data.get("data"):
        return []

    matches = data["data"]
    result = []
    for m in matches:
        home_id = m.get("homeTeam", {}).get("id")
        away_id = m.get("awayTeam", {}).get("id")

        if home_id == team_id:
            goals_scored = int(m.get("homeResult", 0) or 0)
            match_is_home = True
        elif away_id == team_id:
            goals_scored = int(m.get("awayResult", 0) or 0)
            match_is_home = False
        else:
            continue

        if is_home is not None and match_is_home != is_home:
            continue

        result.append((m, goals_scored))
        if len(result) >= limit:
            break

    _matches_cache[cache_key] = result
    _cache_time[cache_key] = now
    return result

def get_today_fixtures():
    today = datetime.now().strftime("%Y-%m-%d")

    data = api_get("/Games/list", {
        "Date": today,
        "Upcoming": "true",
        "Limit": 100,
    })

    if data and data.get("status") == "ok" and data.get("data"):
        return data["data"]

    return []

# === PROBABILITY CALC ===
def poisson_probability(lambda_val: float, target: int = 1):
    import math
    if target == 1:
        return round((1 - math.exp(-lambda_val)) * 100, 1)
    return 0

def calculate_advanced_itb(team_id: int, is_home: bool):
    matches = get_team_matches(team_id, limit=10, is_home=is_home)
    if not matches:
        return None, "No data"

    if len(matches) < 3:
        return None, f"Few matches ({len(matches)})"

    goals_list = [g for _, g in matches]
    lambda_base = sum(goals_list) / len(goals_list)

    weights = [0.15, 0.25, 0.40]
    recent_goals = goals_list[:3]
    weighted_avg = sum(g * w for g, w in zip(recent_goals, weights[:len(recent_goals)])) / sum(weights[:len(recent_goals)])

    lambda_final = lambda_base * 0.6 + weighted_avg * 0.4
    prob = poisson_probability(lambda_final, 1)

    if lambda_final > 1.5 and prob < 60:
        prob = min(75, prob + 10)

    return {
        "probability": prob,
        "lambda": round(lambda_final, 2),
        "avg_goals": round(lambda_base, 2),
        "matches_count": len(matches),
        "confidence": "High" if len(matches) >= 5 else "Medium",
    }, None

# === SCANNER ===
_scan_results = {}

async def scan_matches(user_id: int):
    fixtures = get_today_fixtures()

    if not fixtures:
        return None, "API returned no matches for today. Enter manually: Team1 - Team2"

    recommendations = []

    for fixture in fixtures:
        home_team = fixture.get("homeTeam", {})
        away_team = fixture.get("awayTeam", {})
        home_name = home_team.get("name", "")
        away_name = away_team.get("name", "")
        match_time = fixture.get("date", "??")

        if not home_name or not away_name:
            continue

        home_id, _ = get_team_id(home_name)
        away_id, _ = get_team_id(away_name)

        if not home_id or not away_id:
            continue

        home_stats, _ = calculate_advanced_itb(home_id, is_home=True)
        away_stats, _ = calculate_advanced_itb(away_id, is_home=False)

        if home_stats and home_stats["probability"] >= 65:
            recommendations.append({
                "match": f"{home_name} - {away_name}",
                "time": match_time,
                "team": home_name,
                "side": "home",
                "probability": home_stats["probability"],
                "avg_goals": home_stats["avg_goals"],
                "confidence": home_stats["confidence"],
            })

        if away_stats and away_stats["probability"] >= 65:
            recommendations.append({
                "match": f"{home_name} - {away_name}",
                "time": match_time,
                "team": away_name,
                "side": "away",
                "probability": away_stats["probability"],
                "avg_goals": away_stats["avg_goals"],
                "confidence": away_stats["confidence"],
            })

    recommendations.sort(key=lambda x: x["probability"], reverse=True)
    _scan_results[user_id] = recommendations

    return recommendations, None

# === HANDLERS ===
START_CMDS = ["/start", "start", "nachat", "st"]
SCAN_CMDS = ["skanirovat matshi dnya", "scan", "scan matches", "scan matches today"]
RECS_CMDS = ["moi rekomendatsii", "my recommendations", "recommendations"]

@dp.message(F.text.lower().in_(START_CMDS))
async def cmd_start(message: Message):
    await message.answer(
        "Hello! I scan today matches and look for high ITB 0.5 probability.\n\n"
        "Press button below to scan or enter: Team1 - Team2",
        reply_markup=main_kb
    )

@dp.message(F.text.lower().in_(SCAN_CMDS))
async def scan_handler(message: Message):
    user_id = message.from_user.id
    await message.answer("Scanning today matches... Wait 10-20 seconds.")

    recommendations, error = await scan_matches(user_id)

    if error:
        await message.answer(f"Warning: {error}")
        return

    if not recommendations:
        await message.answer(
            "No matches today with ITB 0.5 probability >= 65%.\n"
            "Try tomorrow or enter manually: Team1 - Team2"
        )
        return

    text = f"Found {len(recommendations)} recommendations:\n\n"

    for i, rec in enumerate(recommendations[:10], 1):
        emoji = "green" if rec["probability"] >= 75 else "yellow"
        text += (
            f"{emoji} **{rec['match']}** ({rec['time']})\n"
            f"   -> ITB 0.5 **{rec['team']}** ({rec['side']})\n"
            f"   Probability: **{rec['probability']}%**\n"
            f"   Avg goals: {rec['avg_goals']}\n"
            f"   Confidence: {rec['confidence']}\n\n"
        )

    await message.answer(text)

@dp.message(F.text.lower().in_(RECS_CMDS))
async def show_recommendations(message: Message):
    user_id = message.from_user.id
    recs = _scan_results.get(user_id, [])

    if not recs:
        await message.answer("First press Scan button")
        return

    text = f"Your recommendations ({len(recs)}):\n\n"
    for i, rec in enumerate(recs[:10], 1):
        emoji = "green" if rec["probability"] >= 75 else "yellow"
        text += f"{emoji} **{rec['match']}** -> ITB 0.5 {rec['team']} - **{rec['probability']}%**\n"

    await message.answer(text)

@dp.message(F.text.contains("-"))
async def manual_analyze(message: Message):
    try:
        teams = message.text.split("-")
        if len(teams) != 2:
            await message.answer("Format: Team1 - Team2")
            return

        t1_name, t2_name = teams[0].strip(), teams[1].strip()
        await message.answer(f"Analyzing `{t1_name}` vs `{t2_name}`...")

        t1_id, t1_found = get_team_id(t1_name)
        t2_id, t2_found = get_team_id(t2_name)

        if not t1_id or not t2_id:
            await message.answer("One or both teams not found")
            return

        home_stats, _ = calculate_advanced_itb(t1_id, is_home=True)
        away_stats, _ = calculate_advanced_itb(t2_id, is_home=False)

        text = f"**{t1_found} vs {t2_found}**\n\n"

        if home_stats:
            emoji = "green" if home_stats["probability"] >= 65 else "yellow" if home_stats["probability"] >= 50 else "red"
            text += (
                f"{emoji} **ITB 0.5 {t1_found} (home)**\n"
                f"   Probability: **{home_stats['probability']}%**\n"
                f"   Lambda: {home_stats['lambda']}\n"
                f"   Avg goals: {home_stats['avg_goals']}\n\n"
            )

        if away_stats:
            emoji = "green" if away_stats["probability"] >= 65 else "yellow" if away_stats["probability"] >= 50 else "red"
            text += (
                f"{emoji} **ITB 0.5 {t2_found} (away)**\n"
                f"   Probability: **{away_stats['probability']}%**\n"
                f"   Lambda: {away_stats['lambda']}\n"
                f"   Avg goals: {away_stats['avg_goals']}\n\n"
            )

        best = None
        if home_stats and away_stats:
            if home_stats["probability"] >= away_stats["probability"] and home_stats["probability"] >= 65:
                best = (t1_found, "home", home_stats["probability"])
            elif away_stats["probability"] >= 65:
                best = (t2_found, "away", away_stats["probability"])

        if best:
            text += f"Recommendation: ITB 0.5 **{best[0]}** ({best[1]}) - {best[2]}%"
        else:
            text += "No confident recommendations (probability < 65%)"

        await message.answer(text)

    except Exception as e:
        logging.exception("Manual analysis error")
        await message.answer("Analysis error. Try later.")

