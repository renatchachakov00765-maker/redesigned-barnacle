# ============ ЗАПУСК ============
async def main():
    scheduler = AsyncIOScheduler(timezone=SCAN_TZ)
    scheduler.add_job(scan_matches, CronTrigger(hour=SCAN_HOUR, minute=0), id="daily_scan")
    scheduler.start()
    logger.info("Бот запущен")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
